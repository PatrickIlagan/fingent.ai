# Optional public URL for deployment or links generated by the app.
APP_URL=http://localhost:3000

# Required only for Google Drive backup/restore. These are Firebase web-app settings,
# not a database credential. Enable Google sign-in and Drive API in the same project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
